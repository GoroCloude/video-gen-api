# TTS providers — ElevenLabs is primary, Google TTS is fallback
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (default)

# Google TTS fallback — set path to your service account JSON
GOOGLE_APPLICATION_CREDENTIALS=/client_secret.apps.googleusercontent.com.json
GOOGLE_TTS_LANGUAGE_CODE=en-US
GOOGLE_TTS_VOICE_NAME=en-US-Neural2-C

# MinIO / S3-compatible
#MINIO_ENDPOINT=https://minio.shumov.eu
MINIO_ENDPOINT=http://homeserver:9002
MINIO_PUBLIC_URL=https://minio-api.shumov.eu  # public base URL returned in API responses (bucket/key appended automatically)
MINIO_ACCESS_KEY=your_access_key_here
MINIO_SECRET_KEY=your_secret_key_here
MINIO_BUCKET=videos
MINIO_REGION=us-east-1

# Video settings
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920                          # 9:16 portrait (story format)
VIDEO_DURATION_SECONDS=10                  # fallback if audio is shorter
VIDEO_EFFECT=none                          # none | zoom-in | zoom-out | pan-left | pan-right | ken-burns | shake
CAPTION_FONT_SIZE=7
CAPTION_PRIMARY_COLOUR=&H00FFFFFF  # white  spoken/highlighted words (ASS &HAABBGGRR format)
CAPTION_OUTLINE_COLOUR=&H00000000  # black  text outline
CAPTION_KARAOKE_COLOUR=&H00808080  # gray   not-yet-spoken words (progressive karaoke fill)
CAPTION_STYLE=word-by-word      # word-by-word | karaoke
CAPTION_POSITION=bottom-center   # bottom-left | bottom-center | bottom-right | middle-left | middle-center | middle-right | top-left | top-center | top-right
CAPTION_MARGIN_V=80              # vertical margin in pixels
CAPTION_MARGIN_H=10              # horizontal margin in pixels

# API
PORT=3000
